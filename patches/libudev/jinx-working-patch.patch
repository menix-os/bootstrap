diff --git libudev-workdir/udev_config.c libudev-workdir/udev_config.c
new file mode 100644
index 0000000..8da05f4
--- /dev/null
+++ libudev-workdir/udev_config.c
@@ -0,0 +1,468 @@
+#include "udev_config.h"
+#include <ctype.h>
+#include <dirent.h>
+#include <errno.h>
+#include <limits.h>
+#include <stdio.h>
+#include <stdlib.h>
+#include <string.h>
+#include <sys/stat.h>
+#include <sys/sysmacros.h>
+
+#define DEFAULT_CONFIG_DIR "/etc/udev/devices.d"
+
+struct kv {
+    char* key;
+    char* value;
+};
+
+struct device_record {
+    char* syspath; // "/sys" + devpath
+    char* devpath;
+    char* sysname;
+    char* subsystem;
+    char* devname; // raw DEVNAME value
+    char* driver;
+    char* parent_devpath; // PARENT= value, may be NULL
+    dev_t devnum;
+    char devnum_type; // 'b', 'c', or 0 if no MAJOR set
+    int has_devnum;
+
+    struct kv* properties;
+    size_t nproperties;
+
+    struct kv* sysattrs;
+    size_t nsysattrs;
+};
+
+static struct device_record* g_records = NULL;
+static size_t g_nrecords = 0;
+static int g_loaded = 0;
+
+// --- Debug logging ---
+//
+// Enable by setting UDEV_DEBUG=1 (or any non-empty, non-"0" value) in the
+// environment. Output goes to stderr with a "libudev:" prefix.
+
+static int debug_enabled(void) {
+    static int cached = -1;
+    if (cached < 0) {
+        const char* env = getenv("UDEV_DEBUG");
+        cached = (env && *env && strcmp(env, "0") != 0) ? 1 : 0;
+    }
+    return cached;
+}
+
+#define DBG(...) \
+    do { \
+        if (debug_enabled()) { \
+            fprintf(stderr, "libudev: "); \
+            fprintf(stderr, __VA_ARGS__); \
+            fputc('\n', stderr); \
+        } \
+    } while (0)
+
+// --- Small helpers ---
+
+static char* xstrdup(const char* s) {
+    return s ? strdup(s) : NULL;
+}
+
+static char* trim(char* s) {
+    while (*s && isspace((unsigned char)*s))
+        s++;
+    char* end = s + strlen(s);
+    while (end > s && isspace((unsigned char)end[-1]))
+        end--;
+    *end = '\0';
+    return s;
+}
+
+static void kv_array_add(struct kv** arr, size_t* n, const char* key, const char* value) {
+    struct kv* na = realloc(*arr, (*n + 1) * sizeof(**arr));
+    if (!na)
+        return;
+    na[*n].key = strdup(key);
+    na[*n].value = value ? strdup(value) : NULL;
+    *arr = na;
+    (*n)++;
+}
+
+static struct device_record* find_by_syspath(const char* syspath) {
+    if (!syspath)
+        return NULL;
+    for (size_t i = 0; i < g_nrecords; i++) {
+        if (strcmp(g_records[i].syspath, syspath) == 0)
+            return &g_records[i];
+    }
+    return NULL;
+}
+
+// --- Parser ---
+
+static const char* config_dir(void) {
+    const char* env = getenv("UDEV_DEVICES_DIR");
+    return (env && *env) ? env : DEFAULT_CONFIG_DIR;
+}
+
+static int parse_file(const char* path, struct device_record* out) {
+    FILE* f = fopen(path, "re");
+    if (!f)
+        return -errno;
+
+    memset(out, 0, sizeof(*out));
+
+    char line[4096];
+    while (fgets(line, sizeof(line), f)) {
+        char* s = trim(line);
+        if (*s == '\0' || *s == '#')
+            continue;
+
+        char* eq = strchr(s, '=');
+        if (!eq)
+            continue;
+        *eq = '\0';
+        char* key = trim(s);
+        char* value = trim(eq + 1);
+
+        // ATTR{name}=value
+        if (strncmp(key, "ATTR{", 5) == 0) {
+            char* end = strchr(key + 5, '}');
+            if (!end)
+                continue;
+            *end = '\0';
+            kv_array_add(&out->sysattrs, &out->nsysattrs, key + 5, value);
+            continue;
+        }
+
+        // Well-known keys: capture into struct fields, but don't echo
+        // PARENT= back through the properties list. PARENT is the NAME of
+        // another device in the same subsystem, or "<subsystem>/<name>"
+        // for a cross-subsystem parent.
+        if (strcmp(key, "PARENT") == 0) {
+            free(out->parent_devpath);
+            out->parent_devpath = strdup(value);
+            continue;
+        }
+
+        // Everything else becomes a property.
+        kv_array_add(&out->properties, &out->nproperties, key, value);
+
+        if (strcmp(key, "NAME") == 0) {
+            free(out->sysname);
+            out->sysname = strdup(value);
+        } else if (strcmp(key, "SUBSYSTEM") == 0) {
+            free(out->subsystem);
+            out->subsystem = strdup(value);
+        } else if (strcmp(key, "DEVNAME") == 0) {
+            free(out->devname);
+            out->devname = strdup(value);
+        } else if (strcmp(key, "DRIVER") == 0) {
+            free(out->driver);
+            out->driver = strdup(value);
+        }
+        // MAJOR/MINOR, if present, are kept as plain properties but the
+        // canonical device number is taken from stat()ing DEVNAME below.
+    }
+    fclose(f);
+
+    // NAME is required and SUBSYSTEM is required: the syspath is
+    // synthesised as /sys/devices/<SUBSYSTEM>/<NAME>. Filenames in the
+    // config dir are not significant.
+    if (!out->sysname || !out->sysname[0]) {
+        fprintf(stderr, "libudev: %s: missing NAME, ignoring\n", path);
+        return -EINVAL;
+    }
+    if (!out->subsystem || !out->subsystem[0]) {
+        fprintf(stderr, "libudev: %s: missing SUBSYSTEM, ignoring\n", path);
+        return -EINVAL;
+    }
+
+    char devpath[PATH_MAX];
+    snprintf(devpath, sizeof(devpath), "/devices/%s/%s", out->subsystem, out->sysname);
+    out->devpath = strdup(devpath);
+
+    char syspath[PATH_MAX];
+    snprintf(syspath, sizeof(syspath), "/sys%s", out->devpath);
+    out->syspath = strdup(syspath);
+
+    // Discover the device number by stat()ing DEVNAME. DEVNAME must be an
+    // absolute path; the major/minor the OS reports for that node is what
+    // libinput and friends will look up via udev_device_new_from_devnum().
+    if (out->devname) {
+        if (out->devname[0] != '/') {
+            fprintf(stderr, "libudev: %s: DEVNAME must be an absolute path, ignoring\n", path);
+            return -EINVAL;
+        }
+        struct stat dst;
+        if (stat(out->devname, &dst) == 0 && (S_ISCHR(dst.st_mode) || S_ISBLK(dst.st_mode))) {
+            out->devnum = dst.st_rdev;
+            out->has_devnum = 1;
+            out->devnum_type = S_ISBLK(dst.st_mode) ? 'b' : 'c';
+        } else {
+            DBG("%s: stat(%s) failed or not a device node: %s", path, out->devname, strerror(errno));
+        }
+    }
+
+    DBG("loaded %s: syspath=%s subsystem=%s devname=%s devnum=%c%u:%u parent=%s props=%zu attrs=%zu",
+        path,
+        out->syspath,
+        out->subsystem ? out->subsystem : "(none)",
+        out->devname ? out->devname : "(none)",
+        out->has_devnum ? out->devnum_type : '-',
+        out->has_devnum ? major(out->devnum) : 0u,
+        out->has_devnum ? minor(out->devnum) : 0u,
+        out->parent_devpath ? out->parent_devpath : "(none)",
+        out->nproperties,
+        out->nsysattrs);
+
+    return 0;
+}
+
+void udev_config_init(void) {
+    if (g_loaded)
+        return;
+    g_loaded = 1;
+
+    const char* dir = config_dir();
+    DBG("scanning config dir %s", dir);
+    DIR* d = opendir(dir);
+    if (!d) {
+        DBG("opendir(%s) failed: %s", dir, strerror(errno));
+        return;
+    }
+
+    struct dirent* de;
+    while ((de = readdir(d))) {
+        if (de->d_name[0] == '.')
+            continue;
+
+        char path[PATH_MAX];
+        snprintf(path, sizeof(path), "%s/%s", dir, de->d_name);
+
+        struct stat st;
+        if (stat(path, &st) < 0 || !S_ISREG(st.st_mode))
+            continue;
+
+        struct device_record rec;
+        if (parse_file(path, &rec) < 0) {
+            // free anything parse_file allocated before failure
+            free(rec.devpath);
+            free(rec.subsystem);
+            free(rec.devname);
+            free(rec.driver);
+            free(rec.parent_devpath);
+            for (size_t i = 0; i < rec.nproperties; i++) {
+                free(rec.properties[i].key);
+                free(rec.properties[i].value);
+            }
+            free(rec.properties);
+            for (size_t i = 0; i < rec.nsysattrs; i++) {
+                free(rec.sysattrs[i].key);
+                free(rec.sysattrs[i].value);
+            }
+            free(rec.sysattrs);
+            continue;
+        }
+
+        struct device_record* na = realloc(g_records, (g_nrecords + 1) * sizeof(*g_records));
+        if (!na)
+            continue;
+        g_records = na;
+        g_records[g_nrecords++] = rec;
+    }
+    closedir(d);
+    DBG("loaded %zu device(s) from %s", g_nrecords, dir);
+}
+
+// --- Lookups ---
+
+char* udev_config_resolve_syspath(const char* syspath) {
+    udev_config_init();
+    if (!syspath)
+        return NULL;
+
+    // Accept "/sys/..." or bare "/..." (treat as devpath)
+    char buf[PATH_MAX];
+    if (strncmp(syspath, "/sys", 4) != 0) {
+        if (syspath[0] != '/')
+            return NULL;
+        snprintf(buf, sizeof(buf), "/sys%s", syspath);
+        syspath = buf;
+    }
+
+    struct device_record* r = find_by_syspath(syspath);
+    DBG("resolve_syspath(%s) -> %s", syspath, r ? r->syspath : "(none)");
+    return r ? strdup(r->syspath) : NULL;
+}
+
+char* udev_config_probe_device(const char* subsystem, const char* sysname) {
+    udev_config_init();
+    if (!subsystem || !sysname)
+        return NULL;
+
+    for (size_t i = 0; i < g_nrecords; i++) {
+        struct device_record* r = &g_records[i];
+        if (r->subsystem && strcmp(r->subsystem, subsystem) == 0 && strcmp(r->sysname, sysname) == 0) {
+            DBG("probe_device(%s, %s) -> %s", subsystem, sysname, r->syspath);
+            return strdup(r->syspath);
+        }
+    }
+    DBG("probe_device(%s, %s) -> (none)", subsystem, sysname);
+    return NULL;
+}
+
+char* udev_config_resolve_devnum(char type, dev_t devnum) {
+    udev_config_init();
+    for (size_t i = 0; i < g_nrecords; i++) {
+        struct device_record* r = &g_records[i];
+        if (r->has_devnum && r->devnum_type == type && r->devnum == devnum) {
+            DBG("resolve_devnum(%c, %u:%u) -> %s", type, major(devnum), minor(devnum), r->syspath);
+            return strdup(r->syspath);
+        }
+    }
+    DBG("resolve_devnum(%c, %u:%u) -> (none)", type, major(devnum), minor(devnum));
+    return NULL;
+}
+
+char* udev_config_get_subsystem(const char* syspath) {
+    udev_config_init();
+    struct device_record* r = find_by_syspath(syspath);
+    return (r && r->subsystem) ? strdup(r->subsystem) : NULL;
+}
+
+char* udev_config_get_driver(const char* syspath) {
+    udev_config_init();
+    struct device_record* r = find_by_syspath(syspath);
+    return (r && r->driver) ? strdup(r->driver) : NULL;
+}
+
+char* udev_config_get_devnode(const char* syspath) {
+    udev_config_init();
+    struct device_record* r = find_by_syspath(syspath);
+    if (!r || !r->devname)
+        return NULL;
+    return strdup(r->devname);
+}
+
+char* udev_config_get_parent_syspath(const char* syspath) {
+    udev_config_init();
+    struct device_record* r = find_by_syspath(syspath);
+    if (!r || !r->parent_devpath)
+        return NULL;
+
+    // PARENT may be either "<subsystem>/<name>" or just "<name>" (in which
+    // case the child's own subsystem is assumed).
+    const char* sep = strchr(r->parent_devpath, '/');
+    char buf[PATH_MAX];
+    if (sep) {
+        snprintf(buf, sizeof(buf), "/sys/devices/%s", r->parent_devpath);
+    } else {
+        if (!r->subsystem)
+            return NULL;
+        snprintf(buf, sizeof(buf), "/sys/devices/%s/%s", r->subsystem, r->parent_devpath);
+    }
+
+    if (!find_by_syspath(buf))
+        return NULL;
+
+    return strdup(buf);
+}
+
+int udev_config_read_uevent(const char* syspath, udev_config_kv_cb cb, void* userdata) {
+    udev_config_init();
+    struct device_record* r = find_by_syspath(syspath);
+    if (!r)
+        return -ENOENT;
+    for (size_t i = 0; i < r->nproperties; i++)
+        cb(r->properties[i].key, r->properties[i].value ? r->properties[i].value : "", userdata);
+    return 0;
+}
+
+char* udev_config_read_sysattr(const char* syspath, const char* sysattr) {
+    udev_config_init();
+    struct device_record* r = find_by_syspath(syspath);
+    if (!r || !sysattr) {
+        DBG("read_sysattr(%s, %s) -> (no device)", syspath, sysattr ? sysattr : "(null)");
+        return NULL;
+    }
+    for (size_t i = 0; i < r->nsysattrs; i++) {
+        if (strcmp(r->sysattrs[i].key, sysattr) == 0) {
+            DBG("read_sysattr(%s, %s) -> %s", syspath, sysattr, r->sysattrs[i].value ? r->sysattrs[i].value : "");
+            return xstrdup(r->sysattrs[i].value);
+        }
+    }
+    DBG("read_sysattr(%s, %s) -> (none)", syspath, sysattr);
+    return NULL;
+}
+
+int udev_config_list_sysattrs(const char* syspath, udev_config_name_cb cb, void* userdata) {
+    udev_config_init();
+    struct device_record* r = find_by_syspath(syspath);
+    if (!r)
+        return -ENOENT;
+    for (size_t i = 0; i < r->nsysattrs; i++)
+        cb(r->sysattrs[i].key, userdata);
+    return 0;
+}
+
+int udev_config_enumerate_devices(udev_config_path_cb cb, void* userdata) {
+    udev_config_init();
+    for (size_t i = 0; i < g_nrecords; i++)
+        cb(g_records[i].syspath, userdata);
+    return 0;
+}
+
+int udev_config_enumerate_subsystems(udev_config_path_cb cb, void* userdata) {
+    udev_config_init();
+    // Emit each distinct subsystem once, as "/sys/class/<subsystem>".
+    char** seen = NULL;
+    size_t nseen = 0;
+
+    for (size_t i = 0; i < g_nrecords; i++) {
+        const char* sub = g_records[i].subsystem;
+        if (!sub)
+            continue;
+        int dup = 0;
+        for (size_t j = 0; j < nseen; j++) {
+            if (strcmp(seen[j], sub) == 0) {
+                dup = 1;
+                break;
+            }
+        }
+        if (dup)
+            continue;
+        char** ns = realloc(seen, (nseen + 1) * sizeof(*seen));
+        if (!ns)
+            break;
+        seen = ns;
+        seen[nseen++] = strdup(sub);
+
+        char path[PATH_MAX];
+        snprintf(path, sizeof(path), "/sys/class/%s", sub);
+        cb(path, userdata);
+    }
+
+    for (size_t j = 0; j < nseen; j++)
+        free(seen[j]);
+    free(seen);
+    return 0;
+}
+
+char* udev_config_lookup_net_ifindex(int ifindex) {
+    udev_config_init();
+    char want[16];
+    snprintf(want, sizeof(want), "%d", ifindex);
+
+    for (size_t i = 0; i < g_nrecords; i++) {
+        struct device_record* r = &g_records[i];
+        if (!r->subsystem || strcmp(r->subsystem, "net") != 0)
+            continue;
+        for (size_t j = 0; j < r->nsysattrs; j++) {
+            if (strcmp(r->sysattrs[j].key, "ifindex") == 0 && r->sysattrs[j].value &&
+                strcmp(r->sysattrs[j].value, want) == 0)
+                return strdup(r->syspath);
+        }
+    }
+    return NULL;
+}
diff --git libudev-workdir/udev_config.h libudev-workdir/udev_config.h
new file mode 100644
index 0000000..fe01972
--- /dev/null
+++ libudev-workdir/udev_config.h
@@ -0,0 +1,57 @@
+#ifndef _LIBUDEV_CONFIG_H_
+#define _LIBUDEV_CONFIG_H_
+
+// Config-driven device registry. Devices are described by Linux-style
+// uevent files under /etc/udev/devices.d/ (override with $UDEV_DEVICES_DIR).
+//
+// File format: KEY=VALUE per line. '#' starts a comment. Blank lines and
+// trailing whitespace are ignored.
+//
+// Recognized keys (others are kept as plain properties):
+//   DEVPATH=/class/...     (required) syspath = "/sys" + DEVPATH
+//   SUBSYSTEM=...          subsystem name
+//   DEVNAME=...            /dev node basename or absolute path
+//   DEVTYPE=...            device subtype
+//   DRIVER=...             driver name
+//   MAJOR=...  MINOR=...   device number
+//   PARENT=/class/...      parent device's DEVPATH (explicit)
+//   ATTR{name}=value       sysattr (udev-rule style, repeatable)
+
+#include <sys/types.h>
+
+typedef void (*udev_config_kv_cb)(const char* key, const char* value, void* userdata);
+typedef void (*udev_config_name_cb)(const char* name, void* userdata);
+typedef void (*udev_config_path_cb)(const char* syspath, void* userdata);
+
+// Idempotent. Scans the config directory on first call.
+void udev_config_init(void);
+
+// Lookups. All returned strings are heap-allocated; caller frees.
+char* udev_config_resolve_syspath(const char* syspath);
+char* udev_config_probe_device(const char* subsystem, const char* sysname);
+char* udev_config_resolve_devnum(char type, dev_t devnum);
+
+// Per-device accessors. Return strdup'd values or NULL.
+char* udev_config_get_subsystem(const char* syspath);
+char* udev_config_get_driver(const char* syspath);
+char* udev_config_get_devnode(const char* syspath);
+char* udev_config_get_parent_syspath(const char* syspath);
+
+// Iterate KEY=VALUE properties of a device (everything that was in the file
+// except ATTR{} entries and the parent directive). Returns 0 on success,
+// negative errno on failure.
+int udev_config_read_uevent(const char* syspath, udev_config_kv_cb cb, void* userdata);
+
+// Sysattrs.
+char* udev_config_read_sysattr(const char* syspath, const char* sysattr);
+int udev_config_list_sysattrs(const char* syspath, udev_config_name_cb cb, void* userdata);
+
+// Enumeration.
+int udev_config_enumerate_devices(udev_config_path_cb cb, void* userdata);
+int udev_config_enumerate_subsystems(udev_config_path_cb cb, void* userdata);
+
+// Lookup network device by ifindex (reads the "ifindex" sysattr of net devices).
+// Returns the syspath as strdup'd string, or NULL.
+char* udev_config_lookup_net_ifindex(int ifindex);
+
+#endif
