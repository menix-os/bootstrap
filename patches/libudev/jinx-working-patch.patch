-char* udev_sysdep_read_sysattr(const char* syspath, const char* sysattr) {
-    if (!syspath || !sysattr)
-        return NULL;
-
-    // Reject attributes with path separators
-    if (strchr(sysattr, '/'))
-        return NULL;
-
-    char path[PATH_MAX];
-    snprintf(path, sizeof(path), "%s/%s", syspath, sysattr);
-
-    // Only read regular files or symlinks to regular files
-    struct stat st;
-    if (stat(path, &st) < 0)
-        return NULL;
-    if (!S_ISREG(st.st_mode))
-        return NULL;
-
-    return read_file_contents(path, 4096);
-}
-
-int udev_sysdep_write_sysattr(const char* syspath, const char* sysattr, const char* value) {
-    if (!syspath || !sysattr || !value)
-        return -EINVAL;
-
-    if (strchr(sysattr, '/'))
-        return -EINVAL;
-
-    char path[PATH_MAX];
-    snprintf(path, sizeof(path), "%s/%s", syspath, sysattr);
-
-    int fd = open(path, O_WRONLY | O_CLOEXEC);
-    if (fd < 0)
-        return -errno;
-
-    size_t len = strlen(value);
-    ssize_t written = write(fd, value, len);
-    close(fd);
-
-    if (written < 0)
-        return -errno;
-    if ((size_t)written != len)
-        return -EIO;
-
-    return 0;
-}
