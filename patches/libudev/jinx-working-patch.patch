-// --- Monitor ---
-
-struct udev_sysdep_monitor {
-    int fd;
-};
-
-struct udev_sysdep_monitor* udev_sysdep_monitor_new(void) {
-    int fd = socket(AF_NETLINK, SOCK_DGRAM | SOCK_CLOEXEC | SOCK_NONBLOCK, NETLINK_KOBJECT_UEVENT);
-    if (fd < 0)
-        return NULL;
-
-    struct udev_sysdep_monitor* mon = calloc(1, sizeof(*mon));
-    if (!mon) {
-        close(fd);
-        return NULL;
-    }
-    mon->fd = fd;
-    return mon;
-}
-
-void udev_sysdep_monitor_free(struct udev_sysdep_monitor* mon) {
-    if (!mon)
-        return;
-    if (mon->fd >= 0)
-        close(mon->fd);
-    free(mon);
-}
-
-int udev_sysdep_monitor_enable(struct udev_sysdep_monitor* mon) {
-    if (!mon)
-        return -EINVAL;
-
-    struct sockaddr_nl addr = {
-        .nl_family = AF_NETLINK,
-        .nl_groups = 1, // KOBJECT_UEVENT multicast group
-    };
-
-    if (bind(mon->fd, (struct sockaddr*)&addr, sizeof(addr)) < 0)
-        return -errno;
-
-    return 0;
-}
-
-int udev_sysdep_monitor_get_fd(struct udev_sysdep_monitor* mon) {
-    if (!mon)
-        return -EINVAL;
-    return mon->fd;
-}
-
-int udev_sysdep_monitor_set_buf_size(struct udev_sysdep_monitor* mon, int size) {
-    if (!mon)
-        return -EINVAL;
-    if (setsockopt(mon->fd, SOL_SOCKET, SO_RCVBUF, &size, sizeof(size)) < 0)
-        return -errno;
-    return 0;
-}
-
-int udev_sysdep_monitor_receive(
-    struct udev_sysdep_monitor* mon,
-    char** action,
-    char** devpath,
-    char** subsystem,
-    udev_sysdep_monitor_cb cb,
-    void* userdata
-) {
-    if (!mon)
-        return -EINVAL;
-
-    char buf[8192];
-    ssize_t len = recv(mon->fd, buf, sizeof(buf) - 1, 0);
-    if (len < 0)
-        return -errno;
-    if (len == 0)
-        return -EIO;
-
-    buf[len] = '\0';
-
-    *action = NULL;
-    *devpath = NULL;
-    *subsystem = NULL;
-
-    // Skip the header (first NUL-terminated string: "ACTION@DEVPATH")
-    const char* header = buf;
-    size_t header_len = strlen(header);
-
-    // Parse header: ACTION@DEVPATH
-    const char* at = strchr(header, '@');
-    if (at) {
-        *action = strndup(header, at - header);
-        *devpath = strdup(at + 1);
-    }
-
-    // Parse KEY=VALUE pairs after header
-    const char* pos = header + header_len + 1;
-    const char* end = buf + len;
-
-    while (pos < end) {
-        size_t entry_len = strlen(pos);
-        if (entry_len == 0) {
-            pos++;
-            continue;
-        }
-
-        const char* eq = strchr(pos, '=');
-        if (eq) {
-            char* key = strndup(pos, eq - pos);
-            const char* value = eq + 1;
-
-            if (strcmp(key, "ACTION") == 0 && !*action)
-                *action = strdup(value);
-            else if (strcmp(key, "DEVPATH") == 0 && !*devpath)
-                *devpath = strdup(value);
-            else if (strcmp(key, "SUBSYSTEM") == 0)
-                *subsystem = strdup(value);
-
-            cb(key, value, userdata);
-            free(key);
-        }
-
-        pos += entry_len + 1;
-    }
-
-    if (!*action || !*devpath) {
-        free(*action);
-        free(*devpath);
-        free(*subsystem);
-        *action = NULL;
-        *devpath = NULL;
-        *subsystem = NULL;
-        return -EINVAL;
-    }
-
-    return 0;
-}
