-int udev_sysdep_read_udev_db(
-    const char* syspath,
-    const char* subsystem,
-    dev_t devnum,
-    udev_sysdep_udevdb_cb cb,
-    void* userdata
-) {
-    char path[PATH_MAX];
-
-    if (devnum > 0) {
-        // Determine block vs char from subsystem or by checking /sys/dev
-        char type = 'c';
-        if (subsystem && strcmp(subsystem, "block") == 0)
-            type = 'b';
-
-        // Also check if the device directory exists under /sys/dev/block
-        char check[PATH_MAX];
-        snprintf(check, sizeof(check), "/sys/dev/block/%u:%u", major(devnum), minor(devnum));
-        if (access(check, F_OK) == 0)
-            type = 'b';
-
-        snprintf(path, sizeof(path), "/run/udev/data/%c%u:%u", type, major(devnum), minor(devnum));
-    } else if (subsystem) {
-        // Extract sysname from syspath
-        const char* sysname = strrchr(syspath, '/');
-        if (!sysname)
-            return -EINVAL;
-        sysname++;
-        snprintf(path, sizeof(path), "/run/udev/data/+%s:%s", subsystem, sysname);
-    } else {
-        return -EINVAL;
-    }
-
-    FILE* f = fopen(path, "re");
-    if (!f)
-        return -errno;
-
-    char line[4096];
-    while (fgets(line, sizeof(line), f)) {
-        size_t len = strlen(line);
-        if (len > 0 && line[len - 1] == '\n')
-            line[len - 1] = '\0';
-
-        if (len < 2 || line[1] != ':')
-            continue;
-
-        cb(line[0], line + 2, userdata);
-    }
-
-    fclose(f);
-    return 0;
-}
