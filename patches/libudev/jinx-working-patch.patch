-#include <sys/sysmacros.h>
-#include <unistd.h>
-
-static char* read_symlink_basename(const char* syspath, const char* name) {
-    char path[PATH_MAX];
-    char target[PATH_MAX];
-    ssize_t len;
-
-    snprintf(path, sizeof(path), "%s/%s", syspath, name);
-    len = readlink(path, target, sizeof(target) - 1);
-    if (len < 0)
-        return NULL;
-    target[len] = '\0';
-
-    char* base = strrchr(target, '/');
-    return strdup(base ? base + 1 : target);
-}
-
-static char* read_file_contents(const char* path, size_t max_size) {
-    int fd = open(path, O_RDONLY | O_CLOEXEC);
-    if (fd < 0)
-        return NULL;
-
-    char* buf = malloc(max_size + 1);
-    if (!buf) {
-        close(fd);
-        return NULL;
-    }
-
-    ssize_t total = 0;
-    while ((size_t)total < max_size) {
-        ssize_t n = read(fd, buf + total, max_size - total);
-        if (n < 0) {
-            if (errno == EINTR)
-                continue;
-            free(buf);
-            close(fd);
-            return NULL;
-        }
-        if (n == 0)
-            break;
-        total += n;
-    }
-    close(fd);
-
-    // Reject binary content
-    for (ssize_t i = 0; i < total; i++) {
-        if (buf[i] == '\0') {
-            free(buf);
-            return NULL;
-        }
-    }
-
-    // Strip trailing whitespace
-    while (total > 0 && (buf[total - 1] == '\n' || buf[total - 1] == '\r' || buf[total - 1] == ' '))
-        total--;
-
-    buf[total] = '\0';
-    return buf;
-}
-
-static int path_has_uevent(const char* path) {
-    char uevent[PATH_MAX];
-    snprintf(uevent, sizeof(uevent), "%s/uevent", path);
-    return access(uevent, F_OK) == 0;
-}
-
-char* udev_sysdep_resolve_syspath(const char* syspath) {
-    if (!syspath)
-        return NULL;
-
-    // Must start with /sys/
-    if (strncmp(syspath, "/sys/", 5) != 0)
-        return NULL;
-
-    char resolved[PATH_MAX];
-    if (!realpath(syspath, resolved))
-        return NULL;
-
-    // Resolved path must still be under /sys/
-    if (strncmp(resolved, "/sys/", 5) != 0)
-        return NULL;
-
-    // Must have a uevent file (i.e., it's a real device)
-    if (!path_has_uevent(resolved))
-        return NULL;
-
-    return strdup(resolved);
-}
-
-int udev_sysdep_read_uevent(const char* syspath, udev_sysdep_uevent_cb cb, void* userdata) {
-    char path[PATH_MAX];
-    snprintf(path, sizeof(path), "%s/uevent", syspath);
-
-    FILE* f = fopen(path, "re");
-    if (!f)
-        return -errno;
-
-    char line[4096];
-    while (fgets(line, sizeof(line), f)) {
-        // Strip newline
-        size_t len = strlen(line);
-        if (len > 0 && line[len - 1] == '\n')
-            line[len - 1] = '\0';
-
-        char* eq = strchr(line, '=');
-        if (!eq)
-            continue;
-
-        *eq = '\0';
-        cb(line, eq + 1, userdata);
-    }
-
-    fclose(f);
-    return 0;
-}
-
-char* udev_sysdep_get_subsystem(const char* syspath) {
-    return read_symlink_basename(syspath, "subsystem");
-}
-
-char* udev_sysdep_get_driver(const char* syspath) {
-    return read_symlink_basename(syspath, "driver");
-}
