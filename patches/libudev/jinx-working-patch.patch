-int udev_sysdep_list_sysattrs(const char* syspath, udev_sysdep_sysattr_list_cb cb, void* userdata) {
-    DIR* dir = opendir(syspath);
-    if (!dir)
-        return -errno;
-
-    struct dirent* de;
-    while ((de = readdir(dir))) {
-        if (de->d_name[0] == '.')
-            continue;
-
-        // Skip uevent - it's not a useful sysattr
-        if (strcmp(de->d_name, "uevent") == 0)
-            continue;
-
-        // Skip directories (but allow symlinks)
-        if (de->d_type == DT_DIR)
-            continue;
-
-        // For unknown types or symlinks, stat to check
-        if (de->d_type == DT_UNKNOWN || de->d_type == DT_LNK) {
-            char path[PATH_MAX];
-            struct stat st;
-            snprintf(path, sizeof(path), "%s/%s", syspath, de->d_name);
-            if (stat(path, &st) < 0)
-                continue;
-            if (S_ISDIR(st.st_mode))
-                continue;
-        }
-
-        cb(de->d_name, userdata);
-    }
-
-    closedir(dir);
-    return 0;
-}
-
-char* udev_sysdep_resolve_devnum(char type, dev_t devnum) {
-    char path[PATH_MAX];
-    char resolved[PATH_MAX];
-
-    snprintf(path, sizeof(path), "/sys/dev/%s/%u:%u", type == 'b' ? "block" : "char", major(devnum), minor(devnum));
-
-    if (!realpath(path, resolved))
-        return NULL;
-
-    return strdup(resolved);
-}
-
-char* udev_sysdep_resolve_devnode(const char* syspath) {
-    char* result = NULL;
-    char path[PATH_MAX];
-    snprintf(path, sizeof(path), "%s/uevent", syspath);
-
-    FILE* f = fopen(path, "re");
-    if (!f)
-        return NULL;
-
-    char line[4096];
-    while (fgets(line, sizeof(line), f)) {
-        size_t len = strlen(line);
-        if (len > 0 && line[len - 1] == '\n')
-            line[len - 1] = '\0';
-
-        if (strncmp(line, "DEVNAME=", 8) == 0) {
-            const char* devname = line + 8;
-            if (devname[0] == '/') {
-                result = strdup(devname);
-            } else {
-                char devpath[PATH_MAX];
-                snprintf(devpath, sizeof(devpath), "/dev/%s", devname);
-                result = strdup(devpath);
-            }
-            break;
-        }
-    }
-
-    fclose(f);
-    return result;
-}
-
-char* udev_sysdep_get_parent_syspath(const char* syspath) {
-    if (!syspath)
-        return NULL;
-
-    // Must be under /sys/devices/ for parent resolution
-    if (strncmp(syspath, "/sys/devices/", 13) != 0)
-        return NULL;
-
-    char* parent = strdup(syspath);
-    if (!parent)
-        return NULL;
-
-    while (1) {
-        char* slash = strrchr(parent, '/');
-        if (!slash || slash == parent) {
-            free(parent);
-            return NULL;
-        }
-
-        *slash = '\0';
-
-        // Stop at /sys/devices
-        if (strcmp(parent, "/sys/devices") == 0) {
-            free(parent);
-            return NULL;
-        }
-
-        // Check if this is a valid device (has uevent)
-        if (path_has_uevent(parent))
-            return parent;
-    }
-}
-
-static void enumerate_devices_recursive(const char* dirpath, udev_sysdep_enumerate_cb cb, void* userdata) {
-    printf("enumerate_devices_recursive(%s, %p, %p)\n", dirpath, cb, userdata);
-
-    DIR* dir = opendir(dirpath);
-    if (!dir)
-        return;
-
-    struct dirent* de;
-    while ((de = readdir(dir))) {
-        if (de->d_name[0] == '.')
-            continue;
-
-        char path[PATH_MAX];
-        snprintf(path, sizeof(path), "%s/%s", dirpath, de->d_name);
-
-        struct stat st;
-        if (lstat(path, &st) < 0)
-            continue;
-
-        // Only recurse into real directories, never follow symlinks
-        // (sysfs symlinks create cycles between /sys/devices and /sys/bus etc.)
-        if (!S_ISDIR(st.st_mode))
-            continue;
-
-        if (path_has_uevent(path))
-            cb(path, userdata);
-
-        enumerate_devices_recursive(path, cb, userdata);
-    }
-
-    closedir(dir);
-}
-
-int udev_sysdep_enumerate_devices(udev_sysdep_enumerate_cb cb, void* userdata) {
-    enumerate_devices_recursive("/sys/devices", cb, userdata);
-    return 0;
-}
-
-int udev_sysdep_enumerate_subsystems(udev_sysdep_enumerate_cb cb, void* userdata) {
-    const char* paths[] = {"/sys/bus", "/sys/class", NULL};
-
-    for (int i = 0; paths[i]; i++) {
-        DIR* dir = opendir(paths[i]);
-        if (!dir)
-            continue;
-
-        struct dirent* de;
-        while ((de = readdir(dir))) {
-            if (de->d_name[0] == '.')
-                continue;
-
-            char path[PATH_MAX];
-            char resolved[PATH_MAX];
-            snprintf(path, sizeof(path), "%s/%s", paths[i], de->d_name);
-
-            if (!realpath(path, resolved))
-                continue;
-
-            cb(resolved, userdata);
-        }
-        closedir(dir);
-    }
-
-    return 0;
-}
