-struct hwdb_header {
-    char signature[8]; // "KSLPHHRH"
-    uint64_t tool_version;
-    uint64_t file_size;
-    uint64_t header_size;
-    uint64_t node_size;
-    uint64_t child_entry_size;
-    uint64_t value_entry_size;
-    uint64_t strings_len;
-    uint64_t nodes_len;
-};
-
-struct hwdb_trie_node {
-    uint64_t prefix_off;
-    uint8_t children_count;
-    uint8_t padding[3];
-    uint32_t values_count;
-};
-
-struct hwdb_trie_child {
-    uint8_t c;
-    uint8_t padding[7];
-    uint64_t child_off;
-};
-
-struct hwdb_trie_value {
-    uint64_t key_off;
-    uint64_t value_off;
-};
-
-struct udev_sysdep_hwdb {
-    void* map;
-    size_t map_size;
-    const struct hwdb_header* header;
-};
-
-struct udev_sysdep_hwdb* udev_sysdep_hwdb_open(void) {
-    static const char* hwdb_paths[] = {
-        "/etc/udev/hwdb.bin",
-        "/usr/lib/udev/hwdb.bin",
-        "/lib/udev/hwdb.bin",
-        NULL,
-    };
-
-    int fd = -1;
-    for (int i = 0; hwdb_paths[i]; i++) {
-        fd = open(hwdb_paths[i], O_RDONLY | O_CLOEXEC);
-        if (fd >= 0)
-            break;
-    }
-    if (fd < 0)
-        return NULL;
-
-    struct stat st;
-    if (fstat(fd, &st) < 0 || st.st_size < (off_t)sizeof(struct hwdb_header)) {
-        close(fd);
-        return NULL;
-    }
-
-    void* map = mmap(NULL, st.st_size, PROT_READ, MAP_SHARED, fd, 0);
-    close(fd);
-    if (map == MAP_FAILED)
-        return NULL;
-
-    const struct hwdb_header* hdr = map;
-    if (memcmp(hdr->signature, "KSLPHHRH", 8) != 0) {
-        munmap(map, st.st_size);
-        return NULL;
-    }
-
-    struct udev_sysdep_hwdb* hwdb = calloc(1, sizeof(*hwdb));
-    if (!hwdb) {
-        munmap(map, st.st_size);
-        return NULL;
-    }
-
-    hwdb->map = map;
-    hwdb->map_size = st.st_size;
-    hwdb->header = hdr;
-
-    return hwdb;
-}
-
-void udev_sysdep_hwdb_close(struct udev_sysdep_hwdb* hwdb) {
-    if (!hwdb)
-        return;
-    if (hwdb->map)
-        munmap(hwdb->map, hwdb->map_size);
-    free(hwdb);
-}
-
-static const char* hwdb_string(const struct udev_sysdep_hwdb* hwdb, uint64_t off) {
-    if (off >= hwdb->map_size)
-        return "";
-    return (const char*)hwdb->map + off;
-}
-
-static const struct hwdb_trie_node* hwdb_node(const struct udev_sysdep_hwdb* hwdb, uint64_t off) {
-    if (off + sizeof(struct hwdb_trie_node) > hwdb->map_size)
-        return NULL;
-    return (const struct hwdb_trie_node*)((const char*)hwdb->map + off);
-}
-
-static void hwdb_collect_values(
-    const struct udev_sysdep_hwdb* hwdb,
-    const struct hwdb_trie_node* node,
-    udev_sysdep_hwdb_cb cb,
-    void* userdata
-) {
-    if (!node)
-        return;
-
-    const struct hwdb_trie_value* values =
-        (const struct hwdb_trie_value*)((const char*)node + sizeof(*node) +
-                                        node->children_count * sizeof(struct hwdb_trie_child));
-
-    for (uint32_t i = 0; i < node->values_count; i++) {
-        const char* key = hwdb_string(hwdb, values[i].key_off);
-        const char* value = hwdb_string(hwdb, values[i].value_off);
-        cb(key, value, userdata);
-    }
-}
-
-static void hwdb_search(
-    const struct udev_sysdep_hwdb* hwdb,
-    const struct hwdb_trie_node* node,
-    const char* search,
-    size_t search_pos,
-    udev_sysdep_hwdb_cb cb,
-    void* userdata
-) {
-    if (!node)
-        return;
-
-    // Match prefix of this node
-    const char* prefix = hwdb_string(hwdb, node->prefix_off);
-    size_t prefix_len = strlen(prefix);
-
-    for (size_t i = 0; i < prefix_len; i++) {
-        if (search[search_pos] == '\0') {
-            // Search string exhausted before prefix matched
-            return;
-        }
-        if (search[search_pos] != prefix[i])
-            return;
-        search_pos++;
-    }
-
-    // Collect values at this node (prefix match)
-    hwdb_collect_values(hwdb, node, cb, userdata);
-
-    // If search string is exhausted, we're done
-    if (search[search_pos] == '\0')
-        return;
-
-    // Find matching child
-    const struct hwdb_trie_child* children = (const struct hwdb_trie_child*)((const char*)node + sizeof(*node));
-
-    for (uint8_t i = 0; i < node->children_count; i++) {
-        if ((char)children[i].c == search[search_pos]) {
-            const struct hwdb_trie_node* child = hwdb_node(hwdb, children[i].child_off);
-            hwdb_search(hwdb, child, search, search_pos + 1, cb, userdata);
-            break;
-        }
-        if (children[i].c == '*') {
-            // Wildcard: try all remaining positions
-            const struct hwdb_trie_node* child = hwdb_node(hwdb, children[i].child_off);
-            for (size_t j = search_pos; search[j] != '\0'; j++) {
-                hwdb_search(hwdb, child, search, j, cb, userdata);
-            }
-            hwdb_search(hwdb, child, search, strlen(search), cb, userdata);
-        }
-    }
-}
-
-int udev_sysdep_hwdb_lookup(
-    struct udev_sysdep_hwdb* hwdb,
-    const char* modalias,
-    udev_sysdep_hwdb_cb cb,
-    void* userdata
-) {
-    if (!hwdb || !modalias)
-        return -EINVAL;
-
-    // Root node is right after the header
-    const struct hwdb_trie_node* root = hwdb_node(hwdb, hwdb->header->header_size);
-    hwdb_search(hwdb, root, modalias, 0, cb, userdata);
-
-    return 0;
-}
