-// --- Queue ---
-
-#include <sys/eventfd.h>
-
-struct udev_sysdep_queue {
-    int fd;
-};
-
-struct udev_sysdep_queue* udev_sysdep_queue_new(void) {
-    // Create an eventfd that is immediately ready (signaled with 1)
-    int fd = eventfd(1, EFD_CLOEXEC | EFD_NONBLOCK);
-    if (fd < 0)
-        return NULL;
-
-    struct udev_sysdep_queue* queue = calloc(1, sizeof(*queue));
-    if (!queue) {
-        close(fd);
-        return NULL;
-    }
-    queue->fd = fd;
-    return queue;
-}
-
-void udev_sysdep_queue_free(struct udev_sysdep_queue* queue) {
-    if (!queue)
-        return;
-    if (queue->fd >= 0)
-        close(queue->fd);
-    free(queue);
-}
-
-int udev_sysdep_queue_get_fd(struct udev_sysdep_queue* queue) {
-    if (!queue)
-        return -EINVAL;
-    return queue->fd;
-}
-
-int udev_sysdep_queue_flush(struct udev_sysdep_queue* queue) {
-    if (!queue || queue->fd < 0)
-        return 0;
-
-    uint64_t val;
-    read(queue->fd, &val, sizeof(val));
-
-    val = 1;
-    write(queue->fd, &val, sizeof(val));
-
-    return 0;
-}
