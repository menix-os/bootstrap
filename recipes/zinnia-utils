#! /bin/sh

name=zinnia-utils
version=0.1
revision=2
hostdeps="gcc pkg-config"
deps="core-libs"


build() {
    _src="${base_dir}/extras/${name}"
    ${OS_TRIPLET}-gcc ${CFLAGS} -o insertmod "${_src}/insertmod.c"
    ${OS_TRIPLET}-gcc ${CFLAGS} -o mount     "${_src}/mount.c"
}

package() {
    mkdir -p     "${dest_dir}/usr/bin"

    cp insertmod "${dest_dir}/usr/bin/insertmod"
    cp mount     "${dest_dir}/usr/bin/mount"
}
