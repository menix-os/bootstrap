{
	"version": "0.2.0",
	"configurations": [
		{
			"type": "lldb",
			"request": "launch",
			"name": "Debug x86_64",
			"targetCreateCommands": [
				"settings set target.source-map /base_dir/sources/zinnia ${workspaceFolder}/sources/zinnia",
				"target create ${workspaceFolder}/build-x86_64/builds/zinnia/x86_64-kernel/release/zinnia.kso",
				"target modules load --file zinnia.kso --slide 0xffffffff80000000"

			],
			"processCreateCommands": [
				"gdb-remote localhost:1234"
			]
		}
	]
}
